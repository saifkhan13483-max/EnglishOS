# EnglishOS — Production Environment Variables Reference
# -------------------------------------------------------
# Copy this file, fill in the values, and set them as
# secrets/env vars in your deployment platform.
# Never commit a file with real values to source control.
#
# Legend:
#   SECRET   = sensitive, must be stored as a secret (never exposed publicly)
#   PUBLIC   = safe to be visible in logs/config (not sensitive)

# ── Database ────────────────────────────────────────────
DATABASE_URL=                    # SECRET  — full PostgreSQL connection string
                                 #           e.g. postgresql://user:pass@host:5432/db

# ── Authentication ──────────────────────────────────────
JWT_SECRET=                      # SECRET  — min 64 random hex chars
JWT_REFRESH_SECRET=              # SECRET  — min 64 random hex chars, different from JWT_SECRET

# ── AI / OpenAI ─────────────────────────────────────────
OPENAI_API_KEY=                  # SECRET  — sk-... from platform.openai.com

# ── Email / Resend ──────────────────────────────────────
RESEND_API_KEY=                  # SECRET  — re_... from resend.com

# ── Analytics / PostHog ─────────────────────────────────
POSTHOG_API_KEY=                 # SECRET  — server-side PostHog project API key

# ── Server Configuration ────────────────────────────────
NODE_ENV=production              # PUBLIC  — must be "production" in prod
PORT=3000                        # PUBLIC  — port the Express server listens on
CLIENT_URL=https://yourdomain.com  # PUBLIC  — full URL of the deployed frontend

# ── Client (Vite) ───────────────────────────────────────
# Set these as build-time environment variables in your CI/CD pipeline.
# They are inlined into the JS bundle at build time (not secret at runtime),
# but VITE_POSTHOG_KEY should be treated as semi-sensitive.

VITE_API_BASE_URL=https://yourdomain.com   # PUBLIC  — base URL for API calls from the browser
VITE_POSTHOG_KEY=                          # SECRET  — PostHog JS project API key (phc_...)
